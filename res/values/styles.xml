<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DollOS.Setup" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/surface_light</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorAccent">@color/accent</item>
    </style>

    <style name="SetupTitle">
        <item name="android:textSize">32sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="SetupSubtitle">
        <item name="android:textSize">17sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">?android:attr/textColorSecondary</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <style name="SetupCard">
        <item name="android:background">@drawable/card_background</item>
        <item name="android:padding">20dp</item>
    </style>
</resources>
